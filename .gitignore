# Build CMake (solo directory di build alla radice: non toccare tools/build_bigrams)
/build/
/build*/
/cmake-build*/

# Artefatti di compilazione
*.o
*.obj
*.a
*.lib
*.dll
*.dylib
*.so
*.exe
*.pdb
*.ilk

# L'eseguibile della demo macOS (build manuale alla radice)
/onehand_mac

# Metadati macOS
.DS_Store

# Modello bigrammi generato da tools/build_bigrams (rigenerabile, ~20 MB)
/data/it.bigrams.bin
# Archivio/estratto bigrammi (fuori repo di norma)
*.word.bigrams
